#!/usr/bin/env bash
# =============================================================================
# Oracle Data Guard E2E Test Configuration
# =============================================================================
# Copy this file to config.env and fill in the values for your environment.
#
# Prerequisites:
#   - Oracle 19c software installed on both hosts (no databases yet)
#   - NFS share mounted at NFS_SHARE on both hosts (read/write)
#   - SSH key-based authentication from the test runner to both hosts
#   - 'expect' installed on both hosts (for automated interactive input)
#   - The oracle user can run sqlplus, dbca, lsnrctl, dgmgrl, rman
# =============================================================================

# --- Jump Host (connect here first, then hop to DB hosts) ---
JUMP_HOST=""                             # IP or hostname of the jump/bastion server
JUMP_SSH_PORT="22"                       # SSH port on jump host
JUMP_USER=""                             # SSH user on jump host
JUMP_KEY=""                              # SSH key for jump host (empty = default)

# --- Host Configuration (reachable from jump host) ---
PRIMARY_HOST=""                          # Primary server hostname or IP
PRIMARY_SSH_PORT="22"                    # SSH port on primary
STANDBY_HOST=""                          # Standby server hostname or IP
STANDBY_SSH_PORT="22"                    # SSH port on standby
SSH_USER="oracle"                        # SSH user on DB hosts (must own Oracle)
SSH_KEY=""                               # SSH key for DB hosts (empty = default, on jump host)
SSH_OPTS="-o StrictHostKeyChecking=no -o ConnectTimeout=10"

# --- Oracle Environment (must match both hosts) ---
ORACLE_HOME=""                           # e.g. /u01/app/oracle/product/19.0.0/dbhome_1
ORACLE_BASE=""                           # e.g. /u01/app/oracle

# --- Test Database ---
TEST_DB_NAME="DGTEST"                    # Database name (db_name)
TEST_DB_UNIQUE_NAME="DGTEST"             # Primary db_unique_name
TEST_STANDBY_DB_UNIQUE_NAME="DGTEST_STB" # Standby db_unique_name
TEST_SYS_PASSWORD="DgTest_2024#"         # SYS password (runtime only, never stored)
TEST_DB_CHARSET="AL32UTF8"               # Character set
TEST_DB_MEMORY_MB=2048                   # SGA + PGA memory (MB)
TEST_REDO_SIZE_MB=200                    # Redo log file size (MB)

# --- Storage Paths (no OMF, no FRA) ---
# These are on the PRIMARY host. Standby paths are derived by the scripts.
TEST_DATA_DIR="${ORACLE_BASE}/oradata/${TEST_DB_NAME}"
TEST_ARCHIVE_DIR="${ORACLE_BASE}/archive/${TEST_DB_NAME}"

# --- NFS ---
NFS_SHARE="/OINSTALL/_dataguard_setup"

# --- Repository ---
REPO_URL=""                              # e.g. https://github.com/yourorg/dataguard_setup.git
REPO_BRANCH="main"                       # Branch to test
REPO_DIR="/home/oracle/dataguard_setup"  # Clone destination on both hosts

# --- FSFO / Observer (Step 9-10) ---
TEST_OBSERVER_USER="DG_OBSERVER"         # Observer username
TEST_OBSERVER_PASSWORD="ObsTest_2024#"   # Observer password
TEST_WALLET_PASSWORD="WalletTest_2024#"  # Oracle Wallet password
FSFO_THRESHOLD=30                        # Fast-Start Failover threshold (seconds)

# --- Test Behaviour ---
SKIP_FSFO="false"                        # Set "true" to skip step 9
SKIP_OBSERVER="true"                     # Set "true" to skip step 10 (observer)
SKIP_TRIGGER="false"                     # Set "true" to skip step 11
SKIP_SECURITY="false"                    # Set "true" to skip step 8
CLEANUP_ON_SUCCESS="true"                # Auto-cleanup after all tests pass
CLEANUP_ON_FAILURE="false"               # Auto-cleanup after a test fails
