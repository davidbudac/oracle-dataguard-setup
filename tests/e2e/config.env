# =============================================================================
# E2E Test Configuration - FILL IN YOUR VALUES BELOW
# =============================================================================
# After filling in, run: ./tests/e2e/run_e2e_test.sh
# Or ask Claude to run the tests for you.
# =============================================================================

# --- Jump Host (connect here first, then hop to DB hosts) ---
JUMP_HOST="dbmint"                 # IP or hostname of the jump/bastion server
JUMP_SSH_PORT="22"           # SSH port on jump host
JUMP_USER="db"                 # SSH user on jump host (e.g. your_username)
JUMP_KEY=""                  # SSH key for jump host (empty = default)

# --- Primary Oracle Server (reachable from jump host) ---
PRIMARY_HOST="localhost"              # SSH target from jump host
PRIMARY_SSH_PORT="2201"        # SSH port
PRIMARY_ORACLE_HOSTNAME="poug-dg1"   # Hostname the DB host knows itself as (for TNS)

# --- Standby Oracle Server (reachable from jump host) ---
STANDBY_HOST="localhost"              # SSH target from jump host
STANDBY_SSH_PORT="2202"        # SSH port
STANDBY_ORACLE_HOSTNAME="poug-dg2"   # Hostname the DB host knows itself as (for TNS)

# --- SSH to DB hosts (from jump host) ---
SSH_USER="oracle"            # SSH user on the DB hosts
SSH_KEY=""                   # SSH key for DB hosts (empty = default, on jump host)
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 -o LogLevel=ERROR"

# --- Oracle Environment (same on both hosts) ---
ORACLE_HOME="/u01/app/oracle/product/19.0.0/dbhome_1"               # e.g. /u01/app/oracle/product/19.0.0/dbhome_1
ORACLE_BASE="/u01/app/oracle"               # e.g. /u01/app/oracle

# --- Test Database Names ---
TEST_DB_NAME="dgtest"
TEST_DB_UNIQUE_NAME="dgtest"
TEST_STANDBY_DB_UNIQUE_NAME="dgtest_s"
TEST_SYS_PASSWORD="DgTest_2024#"
TEST_DB_CHARSET="AL32UTF8"
TEST_DB_MEMORY_MB=2048
TEST_REDO_SIZE_MB=200

# --- Storage (derived, override if needed) ---
TEST_DATA_DIR="${ORACLE_BASE}/oradata/${TEST_DB_NAME}"
TEST_ARCHIVE_DIR="${ORACLE_BASE}/archive/${TEST_DB_NAME}"

# --- NFS (already mounted on both hosts) ---
NFS_SHARE="/OINSTALL/_dataguard_setup"

# --- Git Repository ---
REPO_URL="https://github.com/davidbudac/oracle-dataguard-setup.git"                  # e.g. https://github.com/yourorg/dataguard_setup.git
REPO_BRANCH="fix/bugfix-review-2026-04-19"
REPO_DIR="/home/oracle/dataguard_setup_tests"

# --- FSFO / Observer ---
TEST_OBSERVER_USER="DG_OBSERVER"
TEST_OBSERVER_PASSWORD="ObsTest_2024#"
TEST_WALLET_PASSWORD="WalletTest_2024#"
FSFO_THRESHOLD=30

# --- Behaviour ---
SKIP_FSFO="true"
SKIP_OBSERVER="true"
SKIP_TRIGGER="false"
SKIP_SECURITY="true"
CLEANUP_ON_SUCCESS="true"
CLEANUP_ON_FAILURE="false"
